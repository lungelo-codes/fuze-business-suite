# ERPNext backend URL (server-side only)
ERPNEXT_URL=https://business-suite.fuzedigital.co.za

# ERPNext API credentials (optional - for token auth)
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# Public base URL for ERPNext (client-visible)
NEXT_PUBLIC_ERPNEXT_URL=https://business-suite.fuzedigital.co.za

# Base URL for this app (used in redirects)
NEXT_PUBLIC_BASE_URL=https://app.fuzedigital.co.za

# Optional: public API URL prefix (for client-side fetches through Next.js API routes)
NEXT_PUBLIC_API_URL=

# SaaS frontend security
VERIFICATION_SECRET=replace_with_long_random_secret
NEXTAUTH_SECRET=replace_with_long_random_secret
ADMIN_EMAILS=isaziwebagency@gmail.com,admin@fuzedigital.co.za
